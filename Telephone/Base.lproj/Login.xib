<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.Cocoa.XIB" version="3.0" toolsVersion="22154" targetRuntime="MacOSX.Cocoa" propertyAccessControl="none" useAutolayout="YES">
    <dependencies>
        <deployment identifier="macosx"/>
        <plugIn identifier="com.apple.InterfaceBuilder.CocoaPlugin" version="22154"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <customObject id="-2" userLabel="File's Owner" customClass="LoginWindowController">
            <connections>
                <outlet property="errorLabel" destination="err" id="conn-err"/>
                <outlet property="loginButton" destination="lgi" id="conn-lgi"/>
                <outlet property="passwordField" destination="pwd" id="conn-pwd"/>
                <outlet property="progressIndicator" destination="prg" id="conn-prg"/>
                <outlet property="quitButton" destination="qit" id="conn-qit"/>
                <outlet property="usernameField" destination="usr" id="conn-usr"/>
                <outlet property="window" destination="win" id="conn-win"/>
            </connections>
        </customObject>
        <customObject id="-1" userLabel="First Responder" customClass="FirstResponder"/>
        <customObject id="-3" userLabel="Application" customClass="NSObject"/>
        <window title="Sign In" allowsToolTipsWhenApplicationIsInactive="NO" autorecalculatesKeyViewLoop="NO" releasedWhenClosed="NO" visibleAtLaunch="NO" animationBehavior="default" id="win">
            <windowStyleMask key="styleMask" titled="YES" closable="YES"/>
            <windowPositionMask key="initialPositionMask" leftStrut="YES" bottomStrut="YES"/>
            <rect key="contentRect" x="196" y="121" width="300" height="230"/>
            <rect key="screenRect" x="0.0" y="0.0" width="1440" height="875"/>
            <view key="contentView" id="cv">
                <rect key="frame" x="0.0" y="0.0" width="300" height="230"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <textField verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="tit">
                        <rect key="frame" x="20" y="178" width="260" height="28"/>
                        <textFieldCell key="cell" alignment="center" lineBreakMode="truncatingTail" title="Sign In" id="tit-c">
                            <font key="font" metaFont="systemBold" size="22"/>
                            <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                            <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                        </textFieldCell>
                    </textField>
                    <textField verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="sub">
                        <rect key="frame" x="20" y="158" width="260" height="16"/>
                        <textFieldCell key="cell" alignment="center" lineBreakMode="truncatingTail" title="Enter your credentials" id="sub-c">
                            <font key="font" metaFont="system"/>
                            <color key="textColor" name="secondaryLabelColor" catalog="System" colorSpace="catalog"/>
                            <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                        </textFieldCell>
                    </textField>
                    <textField verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="usr-l">
                        <rect key="frame" x="20" y="116" width="120" height="16"/>
                        <textFieldCell key="cell" alignment="right" lineBreakMode="truncatingTail" sendsActionOnEndEditing="YES" title="Staff ID:" id="usr-l-c">
                            <font key="font" metaFont="system"/>
                            <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                            <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                        </textFieldCell>
                    </textField>
                    <textField verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="usr">
                        <rect key="frame" x="148" y="113" width="292" height="22"/>
                        <textFieldCell key="cell" scrollable="YES" lineBreakMode="clipping" selectable="YES" editable="YES" sendsActionOnEndEditing="YES" state="on" borderStyle="bezel" placeholderString="" drawsBackground="YES" id="usr-c">
                            <font key="font" metaFont="system"/>
                            <color key="textColor" name="controlTextColor" catalog="System" colorSpace="catalog"/>
                            <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                            <allowedInputSourceLocales>
                                <string>NSAllRomanInputSourcesLocaleIdentifier</string>
                            </allowedInputSourceLocales>
                        </textFieldCell>
                        <connections>
                            <outlet property="nextKeyView" destination="pwd" id="kv-1"/>
                        </connections>
                    </textField>
                    <textField verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="pwd-l">
                        <rect key="frame" x="20" y="84" width="120" height="16"/>
                        <textFieldCell key="cell" alignment="right" lineBreakMode="truncatingTail" sendsActionOnEndEditing="YES" title="PIN:" id="pwd-l-c">
                            <font key="font" metaFont="system"/>
                            <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                            <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                        </textFieldCell>
                    </textField>
                    <secureTextField verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="pwd">
                        <rect key="frame" x="148" y="81" width="292" height="22"/>
                        <secureTextFieldCell key="cell" scrollable="YES" lineBreakMode="clipping" selectable="YES" editable="YES" sendsActionOnEndEditing="YES" borderStyle="bezel" drawsBackground="YES" id="pwd-c">
                            <font key="font" metaFont="system"/>
                            <color key="textColor" name="controlTextColor" catalog="System" colorSpace="catalog"/>
                            <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                            <allowedInputSourceLocales>
                                <string>NSAllRomanInputSourcesLocaleIdentifier</string>
                            </allowedInputSourceLocales>
                        </secureTextFieldCell>
                        <connections>
                            <outlet property="nextKeyView" destination="usr" id="kv-2"/>
                        </connections>
                    </secureTextField>
                    <textField hidden="YES" verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="err">
                        <rect key="frame" x="20" y="56" width="420" height="16"/>
                        <textFieldCell key="cell" alignment="center" lineBreakMode="truncatingTail" selectable="YES" title="" id="err-c">
                            <font key="font" metaFont="system"/>
                            <color key="textColor" red="0.78039215686274509" green="0.0" blue="0.0" alpha="1.0" colorSpace="calibratedRGB"/>
                            <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                        </textFieldCell>
                    </textField>
                    <progressIndicator hidden="YES" wantsLayer="YES" horizontalHuggingPriority="750" verticalHuggingPriority="750" maxValue="100" displayedWhenStopped="NO" indeterminate="YES" style="spinning" translatesAutoresizingMaskIntoConstraints="NO" id="prg">
                        <rect key="frame" x="20" y="20" width="16" height="16"/>
                        <constraints>
                            <constraint firstAttribute="width" constant="16" id="prg-w"/>
                            <constraint firstAttribute="height" constant="16" id="prg-h"/>
                        </constraints>
                    </progressIndicator>
                    <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="lgi">
                        <rect key="frame" x="350" y="13" width="90" height="32"/>
                        <constraints>
                            <constraint firstAttribute="width" relation="greaterThanOrEqual" constant="76" id="lgi-w"/>
                        </constraints>
                        <buttonCell key="cell" type="push" title="Log In" bezelStyle="rounded" alignment="center" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="lgi-c">
                            <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                            <font key="font" metaFont="system"/>
                            <string key="keyEquivalent" base64-UTF8="YES">
DQ
</string>
                        </buttonCell>
                        <connections>
                            <action selector="logIn:" target="-2" id="act-lgi"/>
                        </connections>
                    </button>
                    <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="qit">
                        <rect key="frame" x="252" y="13" width="90" height="32"/>
                        <constraints>
                            <constraint firstAttribute="width" relation="greaterThanOrEqual" constant="76" id="qit-w"/>
                        </constraints>
                        <buttonCell key="cell" type="push" title="Quit" bezelStyle="rounded" alignment="center" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="qit-c">
                            <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                            <font key="font" metaFont="system"/>
                        </buttonCell>
                        <connections>
                            <action selector="quit:" target="-2" id="act-qit"/>
                        </connections>
                    </button>
                </subviews>
                <constraints>
                    <constraint firstItem="tit" firstAttribute="top" secondItem="cv" secondAttribute="top" constant="24" id="c-tit-t"/>
                    <constraint firstItem="tit" firstAttribute="leading" secondItem="cv" secondAttribute="leading" constant="20" id="c-tit-l"/>
                    <constraint firstAttribute="trailing" secondItem="tit" secondAttribute="trailing" constant="20" id="c-tit-r"/>

                    <constraint firstItem="sub" firstAttribute="top" secondItem="tit" secondAttribute="bottom" constant="4" id="c-sub-t"/>
                    <constraint firstItem="sub" firstAttribute="leading" secondItem="cv" secondAttribute="leading" constant="20" id="c-sub-l"/>
                    <constraint firstAttribute="trailing" secondItem="sub" secondAttribute="trailing" constant="20" id="c-sub-r"/>

                    <constraint firstItem="usr-l" firstAttribute="leading" secondItem="cv" secondAttribute="leading" constant="20" id="c-usr-l-l"/>
                    <constraint firstItem="usr-l" firstAttribute="width" constant="80" id="c-usr-l-w"/>
                    <constraint firstItem="usr-l" firstAttribute="top" secondItem="sub" secondAttribute="bottom" constant="24" id="c-usr-l-t"/>
                    <constraint firstItem="usr" firstAttribute="leading" secondItem="usr-l" secondAttribute="trailing" constant="8" id="c-usr-l"/>
                    <constraint firstItem="usr" firstAttribute="centerY" secondItem="usr-l" secondAttribute="centerY" id="c-usr-cy"/>
                    <constraint firstAttribute="trailing" secondItem="usr" secondAttribute="trailing" constant="20" id="c-usr-r"/>

                    <constraint firstItem="pwd-l" firstAttribute="leading" secondItem="usr-l" secondAttribute="leading" id="c-pwd-l-l"/>
                    <constraint firstItem="pwd-l" firstAttribute="trailing" secondItem="usr-l" secondAttribute="trailing" id="c-pwd-l-r"/>
                    <constraint firstItem="pwd-l" firstAttribute="top" secondItem="usr" secondAttribute="bottom" constant="10" id="c-pwd-l-t"/>
                    <constraint firstItem="pwd" firstAttribute="leading" secondItem="pwd-l" secondAttribute="trailing" constant="8" id="c-pwd-l"/>
                    <constraint firstItem="pwd" firstAttribute="centerY" secondItem="pwd-l" secondAttribute="centerY" id="c-pwd-cy"/>
                    <constraint firstAttribute="trailing" secondItem="pwd" secondAttribute="trailing" constant="20" id="c-pwd-r"/>

                    <constraint firstItem="err" firstAttribute="leading" secondItem="cv" secondAttribute="leading" constant="20" id="c-err-l"/>
                    <constraint firstAttribute="trailing" secondItem="err" secondAttribute="trailing" constant="20" id="c-err-r"/>
                    <constraint firstItem="err" firstAttribute="top" secondItem="pwd" secondAttribute="bottom" constant="10" id="c-err-t"/>

                    <constraint firstItem="prg" firstAttribute="leading" secondItem="cv" secondAttribute="leading" constant="20" id="c-prg-l"/>
                    <constraint firstItem="prg" firstAttribute="centerY" secondItem="lgi" secondAttribute="centerY" id="c-prg-cy"/>

                    <constraint firstAttribute="bottom" secondItem="lgi" secondAttribute="bottom" constant="13" id="c-lgi-b"/>
                    <constraint firstAttribute="trailing" secondItem="lgi" secondAttribute="trailing" constant="20" id="c-lgi-r"/>
                    <constraint firstItem="qit" firstAttribute="centerY" secondItem="lgi" secondAttribute="centerY" id="c-qit-cy"/>
                    <constraint firstItem="lgi" firstAttribute="leading" secondItem="qit" secondAttribute="trailing" constant="8" id="c-qit-r"/>
                    <constraint firstItem="qit" firstAttribute="width" secondItem="lgi" secondAttribute="width" id="c-qit-w"/>
                </constraints>
            </view>
            <connections>
                <outlet property="initialFirstResponder" destination="usr" id="ifr"/>
            </connections>
            <point key="canvasLocation" x="139" y="139"/>
        </window>
    </objects>
    <resources>
        <image name="NSApplicationIcon" width="128" height="128"/>
    </resources>
</document>
